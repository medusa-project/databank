= form_for @note do |f|
  - if @note.errors.any?
    #error_explanation
      %h2= "#{pluralize(@note.errors.count, "error")} prohibited this note from being saved:"
      %ul
        - @note.errors.full_messages.each do |message|
          %li= message

  .field
    = f.label :dataset_id
    = f.text_field :dataset_id
  .field
    = f.label "Note"
    = f.text_field :body
  .field
    = f.hidden_field :author, value: current_user.email
  .actions
    = f.submit 'Save'
