.panel-group(id="grouping")
  .panel.panel-default
    .panel-heading(id="groupingHeading")
      %h2.panel-title
        %a( role="button" data-toggle="collapse" data-parent="#grouping" href="#groupingPanel" aria-expanded="false" aria-controls="groupingPanel" class="accordion-toggle collapsed" )
          Organize your dataset, especially if it has more than a few files. (click to expand)
    .panel-collapse.collapse(id="groupingPanel" aria-labelledby="groupingHeading" )
      .panel-body
        %p Uploading lots and lots of files in a single dataset can make it more difficult to curate, upload/download, understand, and reuse your data.
        %p
          See our
          =succeed "." do
            %a(href="/guides#group")
              guide on File Grouping
            for tips