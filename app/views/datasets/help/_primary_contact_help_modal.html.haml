.modal.fade(id="primary-contact-modal")
  .modal-dialog.modal-xl
    .modal-content
      .modal-header
        %button(type="button" class="close" data-dismiss="modal" aria-label="Close")
          &times;
        %h2 Selecting a Primary Contact
      .modal-body
        =render partial: 'datasets/select_contact_info'
        .container-fluid
          .pull-right
            %br
            %button(type="button" class="btn btn-success" data-dismiss="modal" data-window-open-url="/help")
              %span(class="glyphicon glyphicon-question-sign")
              Get Help
