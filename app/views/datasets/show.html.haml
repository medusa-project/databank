- if can? :read, @dataset
  = render partial: 'landing'
- else
  = render partial: 'welcome'
  .modal.fade{"id" => "login-prompt", "aria-hidden" => "true", "aria-labelledby" => "agreement-label", :role => "dialog", :tabindex => "-1"}
    .modal-dialog
      .modal-content
        .modal-header
          %h4.modal-title(id = "prompt-title")
            Log in required to View Restricted Dataset
        .modal-footer.container-fluid
          %button{onclick: "window.location = '/login'", type: "button", class: "btn btn-primary", 'data-dismiss' => "modal", id: "login-button"}>
            =image_tag 'favicon.ico'
            %span.glyphicon.glyphicon-log-in
            &nbsp;
            Log in with Illinois NetID
          %button{onclick: "window.location = '/data_curation_network/login'", type: "button", class: "btn btn-primary", 'data-dismiss' => "modal", id: "login-button"}>
            %span.glyphicon.glyphicon-user
            %span.glyphicon.glyphicon-log-in
            &nbsp;
            Log in with Data Curation Network credentials
          %button{:onclick => "window.location = '/help'", type: "button", class: "btn btn-success"}
            %span.glyphicon.glyphicon-question-sign
            Get Help
          %button{:onclick => "window.location = '/'", type: "button", class: "btn btn-danger"}
            %span.glyphicon.glyphicon-remove
            Cancel